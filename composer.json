{
  "name": "marcino0o/openai",
  "type": "library",
  "version": "1.0.7",
  "description": "SDK for communication with open ai",
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "marcin",
      "email": "marcinrozagorski@gmail.com"
    }
  ],
  "require": {
    "guzzlehttp/guzzle": "^7.10",
    "php": "^8.4",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "captainhook/captainhook": "^5.25",
    "captainhook/plugin-composer": "^5.3",
    "infection/infection": "^0.28",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5",
    "rector/rector": "^2.2",
    "symplify/easy-coding-standard": "*"
  },
  "autoload": {
    "psr-4": {
      "Openai\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Openai\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --colors=always",
    "cs": "ecs check src tests",
    "cs:fix": "ecs fix src tests",
    "rector": "rector process --clear-cache",
    "rector:dry": "rector process --dry-run",
    "stan": "phpstan analyse -c phpstan.neon --memory-limit=1G",
    "test": "phpunit --colors=always",
    "infection": "infection --min-msi=85 --threads=4",
    "check:all": [
      "@cs",
      "@rector:dry",
      "@stan",
      "@test"
    ],
    "prepare": [
      "@composer install",
      "vendor/bin/captainhook install -f"
    ]
  },
  "config": {
    "allow-plugins": {
      "captainhook/plugin-composer": true,
      "infection/extension-installer": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  }
}
