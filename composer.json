{
  "name": "marcino0o/openai",
  "type": "library",
  "version": "1.0.9",
  "description": "SDK for communication with open ai",
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "marcin",
      "email": "marcinrozagorski@gmail.com"
    }
  ],
  "require": {
    "guzzlehttp/guzzle": "^7.10",
    "php": "^8.4",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "captainhook/captainhook": "^5.25",
    "captainhook/plugin-composer": "^5.3",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5",
    "rector/rector": "^2.2",
    "symplify/easy-coding-standard": "*"
  },
  "autoload": {
    "psr-4": {
      "Openai\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Openai\\Tests\\": "tests"
    }
  },
  "scripts": {
    "cs": "ecs check src tests",
    "cs:fix": "ecs check src tests --fix",
    "rector": "rector process --dry-run",
    "rector:fix": "rector process --clear-cache",
    "stan": "phpstan analyse -c phpstan.neon --memory-limit=1G",
    "test": "phpunit --testsuite Unit --testsuite Integration --colors=always",
    "check:all": [
      "@cs",
      "@rector",
      "@stan",
      "@test"
    ],
    "prepare": [
      "@composer install",
      "vendor/bin/captainhook install -f"
    ],
    "test:unit": "phpunit --testsuite Unit --colors=always",
    "test:integration": "phpunit --testsuite Integration --colors=always"
  },
  "config": {
    "allow-plugins": {
      "captainhook/plugin-composer": true,
      "infection/extension-installer": true,
      "phpstan/extension-installer": true
    },
    "sort-packages": true
  }
}
